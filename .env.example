# Copy to .env in the project root. Resolution order: process environment > .env > defaults
# (see src/config/settings.py and docs/configuration.md). All public variables use HTSP_ prefix.

# --- Core runtime (load_settings) ---
# Solver backend: simulated_annealing | cirq | cudaq
HTSP_QUANTUM_BACKEND=simulated_annealing

# Paths relative to project root unless absolute
HTSP_OUTPUT_DIR=output
HTSP_INPUT_DIR=input
HTSP_INSTANCE_CONFIG=src/instance_gen_process/config.yaml

# When false, noise is forced off even if solver_config.yaml sets noise.enabled: true
HTSP_ENABLE_NOISE_SIMULATION=false

HTSP_RANDOM_SEED=42

# --- Parallel on-disk experiments (optional; non-empty env overrides solver_config.yaml) ---
# Integer >= 1. Max concurrent CUDA-Q instance solves (experiments.cudaq_parallel).
# HTSP_CUDAQ_MAX_PARALLEL_INSTANCES=1

# Integer >= 1. Max concurrent CPU workers for cirq, brute_force, simulated_annealing.
# HTSP_CPU_MAX_PARALLEL_INSTANCES=1

# --- CUDA-Q native stderr (optional; experiment workflow) ---
# Append fd 2 (native + Python) to a log so TTY progress stays clean. Default log:
#   <HTSP_OUTPUT_DIR>/native_stderr.log
# HTSP_SILENCE_NATIVE_STDERR=1
# HTSP_NATIVE_STDERR_LOG=/path/to/native_stderr.log

# --- Tests only ---
# Real-GPU parallel batch smoke test in tests/test_cudaq_parallel.py
# HTSP_RUN_CUDA_PARALLEL_GPU_TEST=1
