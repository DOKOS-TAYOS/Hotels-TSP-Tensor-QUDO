# Runtime backend: simulated_annealing | cirq | cudaq
ALP_QUANTUM_BACKEND=simulated_annealing

# Local output root (relative paths are resolved from project root)
ALP_OUTPUT_DIR=output
ALP_INPUT_DIR=input
ALP_INSTANCE_CONFIG=src/instance_gen_process/config.yaml

# Research controls
ALP_ENABLE_NOISE_SIMULATION=false
ALP_RANDOM_SEED=42
